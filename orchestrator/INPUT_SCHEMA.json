{
    "title": "Master Orchestrator Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "url": {
            "title": "Website URL",
            "type": "string",
            "description": "URL of the website to analyze",
            "editor": "textfield"
        },
        "maxTimeout": {
            "title": "Maximum Timeout",
            "type": "integer",
            "description": "Maximum time in seconds for each extractor",
            "default": 60,
            "minimum": 1,
            "maximum": 300,
            "editor": "number"
        },
        "retryCount": {
            "title": "Retry Count",
            "type": "integer",
            "description": "Number of times to retry failed extractions",
            "default": 3,
            "minimum": 0,
            "maximum": 5,
            "editor": "number"
        },
        "extractors": {
            "title": "Extractors Configuration",
            "type": "object",
            "description": "Configure which extractors to run",
            "editor": "json",
            "prefill": {
                "websiteContentCrawler": true,
                "color": true,
                "policy": true,
                "contact": false,
                "faq": false,
                "product": false
            }

        },
        "webhookUrl": {
            "title": "Webhook URL",
            "type": "string",
            "description": "Optional URL to call with results when complete",
            "editor": "textfield",
            "nullable": true
        },
        "proxyConfiguration": {
            "title": "Proxy Configuration",
            "type": "object",
            "description": "Optional proxy settings",
            "editor": "json",
            "nullable": true,
            "prefill": {
                "useApifyProxy": true
            }
        }
    },
    "required": ["url"]
}
