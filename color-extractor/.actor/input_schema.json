{
    "title": "Screenshot Capture",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "url": {
            "title": "URL",
            "type": "string",
            "description": "URL to capture screenshot from",
            "editor": "textfield",
            "prefill": "https://apify.com"
        },
        "fullPage": {
            "title": "Full Page Screenshot",
            "type": "boolean",
            "description": "Whether to capture full page or viewport only",
            "default": false
        },
        "quality": {
            "title": "Image Quality",
            "type": "integer",
            "description": "JPEG quality (1-100). Lower means smaller file size. Ignored if format is PNG.",
            "default": 80,
            "minimum": 1,
            "maximum": 100
        }
    },
    "required": ["url"]
}
